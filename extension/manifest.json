{
  "manifest_version": 3,
  "name": "FilmSync İzleme Partisi",
  "version": "1.0.0",
  "description": "Arkadaşlarınızla her web sitesindeki filmleri eşzamanlı olarak izleyin.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "libs/firebase-app.js",
        "libs/firebase-database.js",
        "content.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
